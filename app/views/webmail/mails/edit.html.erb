<% @crud_buttons = proc do |f| %>
  <%= f.submit t("ss.buttons.send"), class: 'btn-primary save js-send', data: { disable_with: t("ss.buttons.sending") } %>
  <%= f.submit t("ss.buttons.draft_save"), class: 'btn-default js-save' %>
<% end %>

<div class="webmail-auto-save-notice"><%= t("webmail.notice.auto_saved") %></div>
<%= render template: "ss/crud/edit" %>
