<dl class="see mod-mail_page-mail_setting">
  <dt><%= @model.t :mail_page_from_conditions %><%= @model.tt :mail_page_from_conditions %></dt>
  <dd><%= f.ss_lines_field :mail_page_from_conditions %></dd>

  <dt><%= @model.t :mail_page_to_conditions %><%= @model.tt :mail_page_to_conditions %></dt>
  <dd><%= f.ss_lines_field :mail_page_to_conditions %></dd>

  <dt><%= @model.t :mail_page_category_ids %><%= @model.tt :mail_page_category_ids %></dt>
  <dd class="wide" style="line-height: 2.5">
    <%= f.hidden_field "mail_page_category_ids[]", value: "", id: nil, class: "hidden-ids" %>
    <%= link_to t("cms.apis.categories.index"), cms_apis_categories_path, class: "ajax-box" %>
  </dd>
  <dd>
    <table class="index ajax-selected">
      <thead>
      <tr>
        <th class="name"><%= t("category.name") %></th>
        <th></th>
      </tr>
      </thead>
      <tbody>
      <% @item.mail_page_categories.each do |cate| %>
        <tr data-id="<%= cate.id %>">
          <td><%= f.hidden_field "mail_page_category_ids[]", value: cate.id, id: nil %><%= cate.name %> (<%= cate.filename %>)</td>
          <td><%= link_to t("ss.buttons.delete"), "#", class: "deselect btn" %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </dd>

  <dt><%= @model.t :mail_page_removal_state %><%= @model.tt :mail_page_removal_state %></dt>
  <dd><%= f.select :mail_page_removal_state, @item.mail_page_removal_state_options %></dd>

  <dt><%= @model.t :arrival_days %><%= @model.tt :arrival_days %></dt>
  <dd class="short"><%= f.number_field :arrival_days, min: 1 %> <span class="postfix"><%= t "datetime.prompts.day" %></span></dd>
</dl>
