<%
  return unless @cur_site.menu_links_visible?
%>
<div class="dropdown dropdown-toggle gws-public-links" data-ref="#gws-public-links-dropdown">
  <button type="button" class="gws-public-links-toggle" aria-label="<%= @cur_site.menu_links_label.presence || t('mongoid.models.gws/link') %>">
    <%# Material Symbols Outlined: link_2 (inlined; the bundled Material Icons font has no link_2) %>
    <svg class="gws-public-links-toggle-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true" role="img">
      <path d="M318-120q-82 0-140-58t-58-140q0-40 15-76t43-64l134-133 56 56-134 134q-17 17-25.5 38.5T200-318q0 49 34.5 83.5T318-200q23 0 45-8.5t39-25.5l133-134 57 57-134 133q-28 28-64 43t-76 15Zm79-220-57-57 223-223 57 57-223 223Zm251-28-56-57 134-133q17-17 25-38t8-44q0-50-34-85t-84-35q-23 0-44.5 8.5T558-726L425-592l-57-56 134-134q28-28 64-43t76-15q82 0 139.5 58T839-641q0 39-14.5 75T782-502L648-368Z"/>
    </svg>
  </button>

  <div class="dropdown-menu gws-public-links-dropdown-menu" id="gws-public-links-dropdown">
    <header class="gws-public-links-menu-header">
      <h2><%= @cur_site.menu_links_label.presence || t('mongoid.models.gws/link') %></h2>
      <% if Gws::Link.allowed?(:read, @cur_user, site: @cur_site) %>
        <%= link_to gws_links_path(site: @cur_site),
              class: "gws-public-links-menu-manage",
              title: t("gws.public_links.manage"),
              aria: { label: t("gws.public_links.manage") },
              data: { turbo: false } do %>
          <%# ic-cms-on is the dark variant (the header uses the white ic-cms-off on its dark background); use the dark one on this white panel %>
          <%= image_tag "/assets/img/ic-cms-on.png", alt: "", width: 19, height: 19,
              class: "gws-public-links-menu-manage-icon" %>
        <% end %>
      <% end %>
    </header>
    <turbo-frame id="gws-public-links-frame" src="<%= menu_gws_public_links_path(site: @cur_site) %>" loading="lazy">
      <%= loading %>
    </turbo-frame>
  </div>
</div>
