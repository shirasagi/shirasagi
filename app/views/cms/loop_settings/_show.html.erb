<dl class="see">
  <dt><%= @model.t :name %></dt>
  <dd><%= @item.name %></dd>

  <dt><%= @model.t :description %></dt>
  <dd><%= @item.description %></dd>

  <dt><%= @model.t :order %></dt>
  <dd><%= @item.order %></dd>

  <dt><%= @model.t :state %></dt>
  <dd><%= @item.label(:state) %></dd>

  <dt><%= @model.t :html_format %></dt>
  <dd>
    <%= @item.label(:html_format) %>
    <% if @item.html_format_liquid? %>
      <%= @item.label(:loop_html_setting_type) %>
    <% end %>
  </dd>
</dl>
