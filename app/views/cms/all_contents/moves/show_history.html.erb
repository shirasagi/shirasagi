<%= render "tabs" %>

<div class="addon-views">
  <div class="addon-view" id="cms-all-contents-move-history-detail">
    <div class="addon-head">
      <h2><%= t("cms.all_contents_moves.history_head") %></h2>
    </div>
    <div class="addon-body">
      <dl class="see">
        <dt>実行日時</dt>
        <dd><%= I18n.l(Time.zone.parse(@history_meta["executed_at"]), format: :picker) %></dd>
        <dt>実行ユーザー名</dt>
        <dd><%= @history_meta["user_name"] %></dd>
        <dt>合計</dt>
        <dd><%= @history_meta["total"] %>件</dd>
        <dt>OK</dt>
        <dd><%= @history_meta["ok"] %>件</dd>
        <dt>エラー</dt>
        <dd><%= @history_meta["error"] %>件</dd>
      </dl>

      <table class="index">
        <thead>
          <tr>
            <th>行</th>
            <th>ページID</th>
            <th>ファイル名</th>
            <th>ステータス</th>
            <th>詳細</th>
          </tr>
        </thead>
        <tbody>
          <% type_labels = { "page" => "ページ", "layout" => "レイアウト", "part" => "パーツ", "node" => "フォルダー" } %>
          <% @history_results.each do |result| %>
            <tr class="<%= result['status'] %>">
              <td><%= result["row"] %></td>
              <td><%= result["id"] %></td>
              <td><%= result["filename"] %></td>
              <td>
                <% if result["status"] == "ok" %>
                  <span class="status-ok">OK</span>
                <% else %>
                  <span class="status-error">エラー</span>
                <% end %>
              </td>
              <td>
                <% if result["confirmations"].present? %>
                  <p>以下のコンテンツにこのページへのリンクが含まれています。手動でリンクを修正してください。</p>
                  <ul>
                    <% result["confirmations"].each do |c| %>
                      <li>
                        <%= type_labels[c["type"]] || c["type"] %>:
                        <%= c["name"] %> (<%= c["filename"] %>)
                      </li>
                    <% end %>
                  </ul>
                <% end %>
                <% if result["errors"] %>
                  <%= safe_join(result["errors"].map { |e| content_tag(:span, e) }, tag(:br)) %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<footer class="send ss-sticky ss-sticky-bottom">
  <%= link_to t("ss.links.back"), cms_all_contents_moves_path, class: "btn" %>
</footer>
