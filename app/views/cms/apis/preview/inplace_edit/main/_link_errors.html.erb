<% errors ||= SS::EMPTY_HASH %>
<% if errors.present? && errors.any? { |_link, result| result.error? } %>
  <div id="errorLinkChecker" class="errorExplanation">
    <h2><%= t "cms.check_links" %></h2>
    <div class="errorExplanationBody">
      <p><%= t "errors.template.check_links" %></p>
      <ul>
        <% errors.select { |_link, result| result.error? }.each do |link, _result| %>
          <li><%= link %> <span class="failure"><%= t('errors.messages.link_check_failure') %></span></li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>
