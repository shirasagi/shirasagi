<%
  addon ||= local_assigns.fetch(:addon, {})
  snippet_select_id = "#{addon[:id]}_loop_snippet_selector"
  loop_setting_select_id = "#{addon[:id]}_loop_setting_id"

  # Liquid のスニペット/テンプレート選択は Cms::Form でのみ意味がある (Cms::Form#render_html が loop_setting.html を参照)。
  # Cms::Layout は html を直接レンダリングするため、これらの UI は表示しない。
  if @item.is_a?(Cms::Form)
    liquid_settings = Cms::LoopSetting.site(@cur_site).liquid
    template_options = liquid_settings.template_type.map { [_1.name, _1.id] }
    snippet_options = liquid_settings.snippet_type.map { [_1.name, _1.id, { "data-snippet" => _1.html.to_s }] }
  else
    template_options = []
    snippet_options = []
  end
%>

<%= code_editor "##{addon[:id]} textarea", mode: :html %>

<dl class="see">
  <dt class="wide"><%= @model.t :html %><%= @model.tt :html %></dt>
  <% if template_options.present? %>
    <dd class="wide">
      <%=
        template_options = render SS::OptionsForSelectComponent.new(options: template_options, selected: @item.loop_setting_id)
        f.select :loop_setting_id,
                 template_options,
                 { include_blank: t('cms.input_directly') },
                 id: loop_setting_select_id,
                 class: 'loop-setting-selector'
      %>
      <%= tt("cms.labels.loop_html") %>
    </dd>
  <% end %>
  <dd class="wide">
    <%= f.text_area :html, style: "height: 400px" %>

    <% if example = @item.try(:form_example_layout_html) %>
      <div class="form-example">
        <button type="button" class="form-example-head example-layout-html" commandfor="<%= addon[:id] %>-example-layout-html" command="toggle-popover"><%= t 'ss.input_example' %></button>
        <div id="<%= addon[:id] %>-example-layout-html" class="form-example-body example-layout-html"><%= example %></div>
      </div>
    <% end %>
  </dd>
  <% if snippet_options.present? %>
    <dd class="wide">
      <%=
        snippet_options = render SS::OptionsForSelectComponent.new(options: snippet_options)
        select_tag(
          'tmp[loop_snippet_selector]',
          snippet_options,
          include_blank: t("cms.labels.snippets"),
          id: snippet_select_id,
          class: 'loop-snippet-selector'
        )
      %>
      <%= tt("cms.labels.snippets") %>
    </dd>
  <% end %>
  <%=
    component = Cms::BodyCheckerComponent.new(
      cur_site: @cur_site, cur_user: @cur_user, cur_node: @cur_node, item: @item, limits: %i[syntax link],
      syntax_check_context: @syntax_context
    )
    syntax_checker_form = render(component)
    if syntax_checker_form.present?
      tag.dd syntax_checker_form, class: "wide"
    end
  %>
</dl>

<%= jquery do %>
  var $addon = $("<%= "##{addon[:id]}" %>");
  var $loopSettingSelect = $addon.find('#<%= loop_setting_select_id %>');
  var $htmlTextarea = $addon.find('textarea[name*="[html]"]');
  var $snippetSelect = $addon.find('.loop-snippet-selector');
  var lockSelector = '#<%= loop_setting_select_id %>';
  var lockTarget = '#<%= addon[:id] %> textarea[name*="[html]"]';

  // ループHTML設定の選択時にテキストエリアをロック/アンロックし、HTMLを読み込む
  if ($loopSettingSelect.length && $htmlTextarea.length) {
    // CodeMirrorエディタの初期化を待つ
    var initAttempts = 0;
    var maxRetries = 50;
    var waitForEditor = function() {
      return new Promise(function(resolve) {
        var tryWait = function() {
          initAttempts++;
          var $codeMirror = $htmlTextarea.next('.CodeMirror');
          if ($codeMirror.length && $codeMirror[0].CodeMirror) {
            resolve(true);
            return;
          }

          if (initAttempts < maxRetries) {
            setTimeout(tryWait, 100);
            return;
          }

          if (window.console && typeof window.console.warn === 'function') {
            window.console.warn("CodeMirror initialization timed out; stop retrying waitForEditor()", {
              selector: lockSelector, target: lockTarget, attempts: initAttempts, maxRetries: maxRetries
            });
          }
          resolve(false);
        };
        tryWait();
      });
    };
    var initLockPromise = waitForEditor();

    // エラーメッセージを取得する関数
    var getErrorMessage = function(xhr) {
      if (xhr.status === 404) {
        return <%= I18n.t("cms.notices.loop_html_not_found").to_json.html_safe %>;
      } else if (xhr.status >= 500) {
        return <%= I18n.t("cms.notices.loop_html_server_error").to_json.html_safe %>;
      }
      return <%= I18n.t("cms.notices.loop_html_load_error").to_json.html_safe %>;
    };

    // エラーメッセージを表示する関数
    var showLoopHtmlError = function(message, retryCallback) {
      // 既存のエラーメッセージを削除
      clearLoopHtmlError();

      // エラーメッセージコンテナを作成（シラサギの標準的なエラー表示構造に従う）
      var $errorDiv = $('<div/>', {
        class: 'loop-html-error errorExplanation',
        role: 'alert',
        'aria-live': 'polite'
      });

      // ヘッダー（シラサギの標準キーを使用）
      var $errorHeader = $('<h2/>').text(<%= I18n.t("errors.template.header.one").to_json.html_safe %>);

      // 本文（シラサギの標準キーを使用）
      var $errorBody = $('<p/>').text(<%= I18n.t("errors.template.body").to_json.html_safe %>);

      // エラーメッセージリスト
      var $errorList = $('<ul/>');
      var $errorItem = $('<li/>').text(message);
      $errorList.append($errorItem);

      $errorDiv.append($errorHeader);
      $errorDiv.append($errorBody);
      $errorDiv.append($errorList);

      // リトライボタンを追加（エラー表示の後に配置）
      if (retryCallback) {
        var $retryButton = $('<button/>', {
          type: 'button',
          class: 'btn btn-retry',
          text: <%= I18n.t("ss.buttons.reload").to_json.html_safe %>
        }).on('click', function() {
          clearLoopHtmlError();
          retryCallback();
        });
        $errorDiv.append($('<div/>', { class: 'error-actions' }).append($retryButton));
      }

      // テキストエリアの前に挿入
      $htmlTextarea.closest('dd').before($errorDiv);
    };

    // エラーメッセージを削除する関数
    var clearLoopHtmlError = function() {
      $htmlTextarea.closest('dl').find('.loop-html-error').remove();
    };

    // テキストエリアをアンロックする関数
    var unlockTextarea = function() {
      $snippetSelect.prop('disabled', false);

      // CodeMirror が存在しない／初期化されていない場合でも、textarea が readonly のまま残らないように解除する
      var editor = $htmlTextarea.data('editor');
      if (editor) {
        editor.setOption('readOnly', false);
        editor.setOption('mode', 'text/html');
      }
      $(lockTarget).prop('readonly', false);
    };
    var loopHtmlLoader = Cms_LoopSettingLoader.create({
      addonSelector: "<%= "##{addon[:id]}" %>",
      loopSettingSelect: "#<%= loop_setting_select_id %>",
      textareaSelector: "textarea[name*=\"[html]\"]",
      snippetSelectSelector: ".loop-snippet-selector",
      apiPathTemplate: '<%= cms_apis_loop_setting_path(id: ":id", site: @cur_site) %>',
      acceptEmptyHtml: true,
      setLoadingState: function() {},
      setTextareaSubmittable: function(_$textarea, submittable) {
        if (submittable) {
          unlockTextarea();
        }
      },
      onBeforeUpdate: function() {
        clearLoopHtmlError();
      },
      setValue: function($textarea, html) {
        var editor = $textarea.data('editor');
        if (editor) {
          editor.setValue(html);
          editor.setOption('mode', 'text/plain');
          editor.setOption('readOnly', true);
        } else {
          $textarea.val(html);
          $textarea.prop('readonly', true);
        }
      },
      onAfterError: function(xhr, status, error) {
        console.error('Loop setting fetch error:', { status: xhr && xhr.status, statusText: xhr && xhr.statusText, message: status, error: error });

        unlockTextarea();

        showLoopHtmlError(getErrorMessage(xhr), function() {
          updateLoopHtml();
        });
      }
    });

    var updateLoopHtml = function() {
      loopHtmlLoader.update();
    };

    // 初期状態を設定
    // 初期状態を設定（既にloop_setting_idが設定されている場合）
    // initLock() は非同期（CodeMirror初期化待ち）なので、完了後に updateLoopHtml() を実行する
    initLockPromise.then(function() {
      if ($loopSettingSelect.val()) {
        updateLoopHtml();
      }
    });

    // 選択変更時にHTMLを更新
    $loopSettingSelect.on('change', updateLoopHtml);
  }

  // スニペットセレクターの初期値を「直接入力」に設定
  if ($snippetSelect.length && !$snippetSelect.val()) {
    $snippetSelect.val('');
  }

  // スニペットの選択処理
  $snippetSelect.on('change', function() {
    // ループHTML設定が選択されている場合はスニペットの挿入を無効にする
    if ($loopSettingSelect.length && $loopSettingSelect.val()) {
      $snippetSelect.val('');
      return;
    }

    var $option = $snippetSelect.find(':selected');
    var snippet = $option.data('snippet');
    $snippetSelect.val('');
    if (!snippet) {
      return;
    }

    if ($htmlTextarea.length === 0) {
      return;
    }

    var editor = $htmlTextarea.data('editor');
    if (!editor) {
      // CodeMirror isn't activated.
      return;
    }

    var doc = editor.getDoc();
    var cursor = doc.getCursor();
    doc.replaceRange(snippet + "\n", cursor);
    editor.focus();
    editor.save();
  });
<% end %>

<% if @syntax_context&.errors.present? && @cur_user.cms_role_permit_any?(@cur_site, "edit_cms_ignore_syntax_check") %>
  <label>
    <%= check_box_tag "ignore_syntax_check", 1, false, id: nil %>
    <%= t("ss.buttons.ignore_alerts_and_save") %>
  </label>
<% end %>
