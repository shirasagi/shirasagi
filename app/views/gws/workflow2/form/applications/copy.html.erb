<%= form_with scope: :item, url: url_for(action: :copy), id: "item-form", method: :post, html: { autocomplete: :off } do |f| %>
  <%= error_messages_for :item %>

  <%= hidden_field_tag :_updated, params[:_updated] || @item.updated if @item.respond_to?(:updated) %>
  <div class="addon-views">
    <%
      addon_options = {}
      addon_options[:id] = "addon-basic"
      addon_options[:head] = t("ss.confirm.clone")
    %>
    <%= render "ss/crud/addon", addon: addon_options do %>
      <dl class="see">
        <dt><%= @model.t :i18n_name %><%= @model.tt :i18n_name %></dt>
        <% if I18n.available_locales.length == 1 %>
          <dd><%= f.text_field :i18n_name, autofocus: pc_browser? %></dd>
        <% else %>
          <dd></dd>
          <% SS.locales_in_order.each_with_index do |lang, index| %>
            <dt class="depth-2 i18n_name"><%= @model.t(:"i18n_name_#{lang}", default: t("ss.options.lang.#{lang}", default: lang.to_s)) %></dt>
            <dd class="depth-2 i18n_name">
              <%= text_field_tag "#{f.object_name}[i18n_name_translations][#{lang}]", @item.i18n_name_translations[lang], autofocus: index == 0 && pc_browser? %>
            </dd>
          <% end %>
        <% end %>
      </dl>
    <% end %>
  </div>

  <footer class="send">
    <%= f.submit t("ss.buttons.copy"), class: 'btn-primary save', data: { disable_with: t("ss.buttons.copy") } %>
    <%= link_to t("ss.buttons.cancel"), url_for(action: :show), class: 'btn-default' %>
  </footer>
<% end %>
