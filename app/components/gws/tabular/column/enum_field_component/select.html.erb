<%= render Gws::Tabular::Column::BaseComponent.new(cur_site: cur_site, cur_user: cur_user, type: type, column: column) do %>
  <%=
    options = select_options.map do |select_option|
      select_option_translations = Gws::Column.to_translations(select_option)
      label = select_option_translations[I18n.locale] || select_option_translations[I18n.default_locale]
      [ label, select_option ]
    end
    choices = render ::SS::OptionsForSelectComponent.new(options: options, selected: normalized_values.first)
    select_tag("#{form.object_name}[col_#{column.id}][]", choices, include_blank: !column.required?)
  %>
<% end %>
