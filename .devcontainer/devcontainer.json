{
  "name": "shirasagi-devcontainer",
  "dockerComposeFile": "compose.yml",
  "service": "shirasagi",
  "workspaceFolder": "/workspaces/shirasagi",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/rails/devcontainer/features/activestorage": {}
  },

  "containerEnv": {
    "LANG": "ja_JP.UTF-8",
    "LC_ALL": "ja_JP.UTF-8",
    "TZ": "Asia/Tokyo"
  },

  // ローカルPCからアクセスできるように、コンテナ内のポートを転送する
  "forwardPorts": [3000, 9200, 10143, 10587],

  // コンテナ初回作成時に一度だけ実行するセットアップ
  "postCreateCommand": "bin/setup --skip-server",
  // コンテナ起動のたびに Web サーバーを立ち上げる
  "postStartCommand": ".devcontainer/start-web-server.sh"
}
